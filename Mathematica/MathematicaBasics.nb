Cell[BoxData[
 FractionBox[
  RowBox[{"5", " ", 
   SuperscriptBox["x", "3"]}], 
  RowBox[{
   RowBox[{"-", "1"}], "+", 
   SuperscriptBox["\[ExponentialE]", "x"]}]]], "Output",
 CellChangeTimes->{3.920460003429484*^9, 3.9204600501144576`*^9, 
  3.940000722092475*^9},
