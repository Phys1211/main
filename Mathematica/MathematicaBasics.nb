 CellChangeTimes->{3.9204598863884983`*^9, 3.9204600397772756`*^9, 
  3.9400005978780503`*^9},
 CellLabel->
  "Out[153]=",ExpressionUUID->"9fc0ce71-f5a8-4934-850a-600914ec0983"],

Cell[BoxData[
 FractionBox["24", 
  RowBox[{
   RowBox[{"-", "1"}], "+", 
   SuperscriptBox["\[ExponentialE]", "2"]}]]], "Output",
