Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Sin", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", 
     RowBox[{"4", "\[Pi]"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.7319350243250074`*^9, 3.731935029417118*^9}, {
  3.7319350933097367`*^9, 3.73193509391383*^9}, {3.795122798335429*^9, 
  3.7951228178785753`*^9}, {3.9404148438775063`*^9, 3.9404149086825504`*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"588ab7ee-8ba7-4da0-99ca-b48a0fa2b366"],

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Sin", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", 
       RowBox[{"4", "\[Pi]"}]}], "}"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"Sin", "[", "x", "]"}]}], "}"}]}], ",", 
     RowBox[{"LabelStyle", "->", 
      RowBox[{"Directive", "[", 
       RowBox[{"Bold", ",", "Large"}], "]"}]}]}], "]"}], "\n", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Sin", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", 
       RowBox[{"4", "\[Pi]"}]}], "}"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<x\>\"", ",", "\"\<Sin[x]\>\""}], "}"}]}], ",", 
     RowBox[{"LabelStyle", "->", "Red"}]}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Sin", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", 
       RowBox[{"4", "\[Pi]"}]}], "}"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Rotate", "[", 
         RowBox[{"\"\<x-axis\>\"", ",", 
          RowBox[{"90", " ", "Degree"}]}], "]"}], ",", "\"\<Sin[x]\>\""}], 
       "}"}]}]}], "]"}], "\n", 
   RowBox[{"Plot", "[", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"Sin", "[", "x", "]"}], "2"], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", 
       RowBox[{"4", "\[Pi]"}]}], "}"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Subscript", "[", 
         RowBox[{"\"\<x\>\"", ",", "0"}], "]"}], ",", 
        RowBox[{
         RowBox[{"Superscript", "[", 
          RowBox[{"\"\<Sin\>\"", ",", "2"}], "]"}], "[", "\"\<x\>\"", "]"}]}],
        "}"}]}]}], "]"}], "\n", "\[IndentingNewLine]", "\n", 
   "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.9404153832931137`*^9, 3.9404155084031796`*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"44699fd4-91d9-4f2e-bfcd-e71eaea86df7"]
}, Open  ]],

