Cell[CellGroupData[{
Cell["Mathematica Plotting and Manipulate", "Title",
 CellChangeTimes->{{3.731934224128369*^9, 
  3.731934251245076*^9}},ExpressionUUID->"2b570f8c-956c-41b7-85e1-\
